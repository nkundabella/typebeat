PORT=5000

# OPTION A: Neon Serverless Postgres (Cloud)
# 1. Create a project in your Neon dashboard (https://neon.tech)
# 2. Copy the connection string ending with "?sslmode=require" and paste it here:
# DATABASE_URL=postgresql://neondb_owner:YOUR_NEON_PASSWORD@ep-neon-service.aws.neon.tech/neondb?sslmode=require

# OPTION B: Local PostgreSQL (Localhost)
DATABASE_URL=postgresql://postgres:YOUR_LOCAL_PASSWORD@localhost:5432/postgres
